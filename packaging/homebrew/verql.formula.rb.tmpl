class Verql < Formula
  desc "Fast, extensible desktop database client"
  homepage "https://github.com/arshad-shah/verql"
  version "{{VERSION}}"
  url "https://github.com/arshad-shah/verql/releases/download/v#{version}/verql-#{version}-x86_64.AppImage"
  sha256 "{{SHA_APPIMAGE}}"
  license "MIT"

  # AppImages are self-contained; they only need a FUSE runtime at launch.
  depends_on :linux

  def install
    # Homebrew downloads the URL into the staging dir under its basename.
    appimage = "verql-#{version}-x86_64.AppImage"
    libexec.install appimage => "verql.AppImage"
    chmod 0755, libexec/"verql.AppImage"

    (bin/"verql").write <<~SH
      #!/bin/bash
      exec "#{libexec}/verql.AppImage" "$@"
    SH
  end

  test do
    assert_path_exists libexec/"verql.AppImage"
  end
end

{
  "name": "verql",
  "version": "1.1.0",
  "private": true,
  "description": "Verql — a fast, extensible desktop database client.",
  "license": "MIT",
  "author": "Arshad Shah",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arshad-shah/verql.git"
  },
  "bugs": {
    "url": "https://github.com/arshad-shah/verql/issues"
  },
  "homepage": "https://verql.arshadshah.com",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild --only better-sqlite3",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version": "changeset version",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "build:icons": "rsvg-convert -w 1024 -h 1024 build/icon.svg -o build/icon.png && rsvg-convert -w 1024 -h 1024 build/icon-light.svg -o build/icon-light.png && npx --yes png2icons build/icon.png build/icon -all",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@arshad-shah/swift-chart": "^1.3.0",
    "@dagrejs/dagre": "3.0.0",
    "@floating-ui/react": "0.27.19",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "4.7.0",
    "@xyflow/react": "12.10.2",
    "ag-grid-community": "35.2.1",
    "ag-grid-react": "35.2.1",
    "better-sqlite3": "12.8.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "csv-parse": "6.2.1",
    "csv-stringify": "6.7.0",
    "dompurify": "^3.4.0",
    "electron-updater": "6.8.9",
    "ioredis": "5.10.1",
    "lucide-react": "1.7.0",
    "mime-db": "1.52.0",
    "mime-types": "2.1.35",
    "monaco-editor": "0.55.1",
    "mongodb": "7.1.1",
    "mysql2": "3.20.0",
    "pg": "8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "snowflake-sdk": "2.4.0",
    "sql-formatter": "^15.8.0",
    "ssh2": "1.17.0",
    "tailwind-merge": "3.5.0",
    "zod": "^4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@electron/rebuild": "4.0.4",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-mcp": "0.5.0",
    "@storybook/addon-themes": "10.3.5",
    "@storybook/addon-vitest": "10.3.5",
    "@storybook/react": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/dompurify": "^3.2.0",
    "@types/node": "25.5.2",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ssh2": "1.15.5",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/browser-playwright": "4.1.6",
    "@vitest/coverage-v8": "4.1.6",
    "electron": "39.8.10",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "jsdom": "29.0.2",
    "playwright": "1.59.1",
    "storybook": "10.3.5",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "7.3.2",
    "vitest": "4.1.6"
  },
  "build": {
    "appId": "com.electron.verql",
    "productName": "Verql",
    "artifactName": "${name}-${version}-${arch}.${ext}",
    "npmRebuild": true,
    "buildDependenciesFromSource": false,
    "afterPack": "./build/afterPack.cjs",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "identity": null
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}

{
  "name": "dbterm",
  "version": "1.0.0",
  "description": "A full-featured terminal database client — like IntelliJ's DB editor in your terminal",
  "bin": {
    "dbterm": "./dist/index.js"
  },
  "type": "commonjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ansi-escapes": "^7.0.0",
    "better-sqlite3": "^11.9.1",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.10.1",
    "cli-table3": "^0.6.5",
    "conf": "^13.1.0",
    "inquirer": "^9.3.7",
    "mongodb": "^6.15.0",
    "mssql": "^11.0.1",
    "mysql2": "^3.14.0",
    "nanospinner": "^1.2.2",
    "node-sql-parser": "^4.18.0",
    "pg": "^8.14.1",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/blessed": "^0.1.25",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.13",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}

{
  "name": "nova",
  "version": "0.2.5",
  "private": true,
  "description": "Nova — a fast, extensible desktop database client.",
  "license": "MIT",
  "author": "Arshad Shah",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arshad-shah/nova.git"
  },
  "bugs": {
    "url": "https://github.com/arshad-shah/nova/issues"
  },
  "homepage": "https://github.com/arshad-shah/nova#readme",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild --only better-sqlite3",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version": "changeset version",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "build:icons": "rsvg-convert -w 1024 -h 1024 build/icon.svg -o build/icon.png && rsvg-convert -w 1024 -h 1024 build/icon-light.svg -o build/icon-light.png && echo 'Run: npx --yes png2icons build/icon.png build/icon -ic -i  (icns + ico). electron-icon-builder removed due to unpatched svg2png/request CVEs (GHSA-mpp5-2x55-49xw, GHSA-p8p7-x288-28g6).'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@dagrejs/dagre": "3.0.0",
    "@floating-ui/react": "0.27.19",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "4.7.0",
    "@xyflow/react": "12.10.2",
    "ag-grid-community": "35.2.1",
    "ag-grid-react": "35.2.1",
    "better-sqlite3": "12.8.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "csv-parse": "6.2.1",
    "csv-stringify": "6.7.0",
    "dompurify": "^3.4.0",
    "ioredis": "5.10.1",
    "lucide-react": "1.7.0",
    "monaco-editor": "0.55.1",
    "mongodb": "7.1.1",
    "mysql2": "3.20.0",
    "pg": "8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "3.8.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "snowflake-sdk": "2.4.0",
    "ssh2": "1.17.0",
    "tailwind-merge": "3.5.0",
    "zod": "^4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@electron/rebuild": "4.0.4",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-mcp": "0.5.0",
    "@storybook/addon-themes": "10.3.5",
    "@storybook/addon-vitest": "10.3.5",
    "@storybook/react": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/dompurify": "^3.2.0",
    "@types/node": "25.5.2",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ssh2": "1.15.5",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/browser-playwright": "4.1.3",
    "@vitest/coverage-v8": "4.1.3",
    "electron": "39.8.10",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "jsdom": "29.0.2",
    "playwright": "1.59.1",
    "storybook": "10.3.5",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "7.3.2",
    "vitest": "4.1.3"
  },
  "build": {
    "npmRebuild": true,
    "buildDependenciesFromSource": false,
    "afterPack": "./build/afterPack.cjs",
    "files": [
      "out/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "identity": null
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "@electron/rebuild"
    ],
    "overrides": {
      "axios@<1.15.1": ">=1.15.1",
      "form-data@<2.5.4": ">=2.5.4",
      "fast-uri@<3.1.2": ">=3.1.2",
      "xmldom": "npm:@xmldom/xmldom@^0.8.13",
      "@xmldom/xmldom@<0.8.13": ">=0.8.13",
      "fast-xml-parser@<4.4.1": ">=4.4.1",
      "fast-xml-builder@<1.1.7": ">=1.1.7",
      "tough-cookie@<4.1.3": ">=4.1.3",
      "yargs-parser@<5.0.1": ">=5.0.1",
      "dompurify@<3.4.5": ">=3.4.5",
      "follow-redirects@<1.16.0": ">=1.16.0",
      "qs@<6.14.1": ">=6.14.1",
      "phin@<3.7.1": ">=3.7.1",
      "postcss@<8.5.10": ">=8.5.10",
      "hono@<4.12.18": ">=4.12.18",
      "ip-address@<10.2.0": ">=10.2.0",
      "brace-expansion": ">=5.0.6",
      "ws@<8.20.0": ">=8.20.0",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1",
      "fast-xml-parser@<5.7.0": ">=5.7.0"
    }
  }
}

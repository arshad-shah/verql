{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "composite": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./out",
    "declaration": true,
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["src/main/**/*", "src/preload/**/*", "shared/**/*", "electron.vite.config.ts"]
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "composite": true,
    "strict": true,
    "jsx": "react-jsx",
    "outDir": "./out/renderer",
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./src/renderer/src/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["src/renderer/src/**/*", "src/preload/index.d.ts", "shared/**/*"]
}
